@includes[
    #include "tokens.hpp"
    #include "ast.hpp"
]

@utilities[
    ast* tree;
]

@token_obj[token::Token]
@token_type[token::TokenKind]

@declarations[
    token INT
    token ADD
    token SUB
    token MUL
    token DIV

    ast*        CALC_EXP
    arith_expr* ADD_EXP
    arith_expr* SUB_EXP
    arith_expr* MUL_EXP
    arith_expr* DIV_EXP
]

@start[CALC_EXP]
@productions[
    CALC_EXP : ADD_EXP $$ {
        return new calc_expr($1);
    };

    ADD_EXP 
    : SUB_EXP ADD ADD_EXP {
        return new arith_expr($2.op, $1, $3);
    }
    | SUB_EXP {
        return $1;
    };
    
    SUB_EXP
    : MUL_EXP SUB SUB_EXP {
        return new arith_expr($2.op, $1, $3);
    }
    | MUL_EXP {
        return $1;
    };

    MUL_EXP
    : DIV_EXP MUL MUL_EXP {
        return new arith_expr($2.op, $1, $3);
    }
    | DIV_EXP {
        return $1;
    };

    DIV_EXP
    : INT DIV DIV_EXP {
        return new arith_expr($2.op, $1, $3);
    }
    | INT {
        return new int_expr($1);
    };
]